# CRE Secrets — shared across all workflows in this project.
# Replace placeholder values with real keys before running.
#
# For simulation (bunx cre simulate), secrets may also be loaded
# from environment variables or a .env file depending on CRE CLI version.

secretsNames:
    SXT_API_KEY:
        - SXT_API_KEY_ALL
    LLM_API_KEY:
        - LLM_API_KEY_ALL